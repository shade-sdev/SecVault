        <!-- Button Section -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.1*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Separator -->
            <Rectangle Grid.Row="0"
                       Height="0.25"
                       Width="800"
                       Fill="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0" />

            <Grid Grid.Row="1"
                  Margin="20,0,20,0"
                  VerticalAlignment="Center">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.8*" />
                    <ColumnDefinition Width="0.2*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      HorizontalAlignment="Left">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <!-- Cancel Button -->
                    <moderncontrols:ModernButton Grid.Column="0"
                                                 Margin="10,0,10,0"
                                                 DefaultBackground="#292929"
                                                 HoverBackground="DarkGray"
                                                 PressedBackground="Black"
                                                 HorizontalAlignment="Center"
                                                 Content="Cancel"
                                                 FontFamily="Roboto"
                                                 FontWeight="SemiBold"
                                                 FontSize="12"
                                                 CornerRadius="5"
                                                 Height="40"
                                                 Width="80" />

                    <!-- View Password Button -->
                    <moderncontrols:ModernButton Grid.Column="1"
                                                 Margin="10,0,10,0"
                                                 DefaultBackground="#292929"
                                                 HoverBackground="DarkGray"
                                                 PressedBackground="Black"
                                                 HorizontalAlignment="Center"
                                                 Icon="{wpf:MaterialIconExt Kind=Eye}"
                                                 FontFamily="Roboto"
                                                 FontWeight="SemiBold"
                                                 FontSize="12"
                                                 CornerRadius="5"
                                                 Height="40"
                                                 Width="80" />

                    <!-- Password Type ComboBox -->
                    <moderncontrols:ModernComboBox Grid.Column="2"
                                                   Margin="10,0,10,0"
                                                   DefaultBackground="#292929"
                                                   HoverBackground="DarkGray"
                                                   PressedBackground="Black"
                                                   HorizontalAlignment="Center"
                                                   Text="Type"
                                                   FontFamily="Roboto"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   CornerRadius="5"
                                                   Height="40"
                                                   Width="120">
                        <ComboBoxItem>Password</ComboBoxItem>
                        <ComboBoxItem>Password</ComboBoxItem>
                        <ComboBoxItem>Password</ComboBoxItem>
                    </moderncontrols:ModernComboBox>

                </Grid>

                <!-- Save Button -->
                <moderncontrols:ModernButton Grid.Column="1"
                                             Margin="10,0,10,0"
                                             DefaultBackground="#292929"
                                             HoverBackground="DarkGray"
                                             PressedBackground="Black"
                                             HorizontalAlignment="Right"
                                             Content="Save"
                                             FontFamily="Roboto"
                                             FontWeight="SemiBold"
                                             FontSize="12"
                                             CornerRadius="5"
                                             Height="40"
                                             Width="80" />
            </Grid>

        </Grid>

    </Grid>

</Window>
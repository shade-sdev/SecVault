<Window x:Class="SecVault.MVVM.View.Form.PasswordForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:viewModel="clr-namespace:SecVault.MVVM.ViewModel"
        xmlns:reusableControl="clr-namespace:SecVault.MVVM.View.ReusableControl"
        mc:Ignorable="d"
        Title="Manage Password"
        Height="700"
        Width="1150"
        Background="#191919"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        MouseDown="OnWindow_Drag">
    
    <!-- Init DataContext -->
    <Window.DataContext>
        <viewModel:PasswordFormViewModel />
    </Window.DataContext>

    <!-- Init Rounded Corners -->
    <Window.Clip>
        <RectangleGeometry
            Rect="0,0,1150,700"
            RadiusX="5"
            RadiusY="5" />
    </Window.Clip>
    
    <Grid>

        <reusableControl:FormTextBox Valid="False"
                                     TextBoxLabel="Email"
                                     TextBoxContent="{Binding ElementName=Window, Path=DataContext.TextBox, Mode=TwoWay}"
                                     ValidationLabel="Invalid email address">

        </reusableControl:FormTextBox>

    </Grid>
    
</Window>